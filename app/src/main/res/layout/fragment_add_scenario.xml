<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView
        android:layout_width="match_parent"
        android:fillViewport="true"
        android:layout_height="match_parent">
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home"
    tools:context=".fragments.AddScenarioFragment">

    <TextView
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Start_time_text"
        android:textSize="@dimen/big_text"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/long_margin"
        app:layout_constraintBottom_toTopOf="@id/tvStartTime"
        app:layout_constraintStart_toStartOf="@id/tvStartTime"
        app:layout_constraintEnd_toEndOf="@id/tvStartTime"
        />
    <TextView
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cvScenarioAttrib"
        app:layout_constraintEnd_toStartOf="@id/tvEndTime"
        android:id="@+id/tvStartTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/start_time"
        android:textSize="@dimen/uuBig_text" />

    <TextView
        android:textColor="@color/white"
        android:layout_marginBottom="@dimen/long_margin"
        android:textSize="@dimen/big_text"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/end_time_text"
        app:layout_constraintBottom_toTopOf="@id/tvEndTime"
        app:layout_constraintStart_toStartOf="@id/tvEndTime"
        app:layout_constraintEnd_toEndOf="@id/tvEndTime"
        />
    <TextView
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvStartTime"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cvScenarioAttrib"
        android:id="@+id/tvEndTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/start_time"
        android:textSize="@dimen/uuBig_text" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvScenarioAttrib"
        android:layout_width="match_parent"
        android:layout_height="@dimen/no_margin"
        android:layout_marginTop="@dimen/hhLong_margin"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="@dimen/uLong_margin"
        app:layout_constraintBottom_toTopOf="@id/bottomLayout">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:fillViewport="true"
        android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:padding="@dimen/long_margin"
            android:layout_height="match_parent">
        <LinearLayout
            android:id="@+id/layoutRepeat_nDays"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/etScenarioName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvRepeatText"
                android:text="@string/repeat"
                android:textSize="@dimen/big_text"
                android:textStyle="bold"/>
            <TextView
                android:layout_marginVertical="@dimen/short_margin"
                android:id="@+id/tvGetDays"
                android:layout_marginStart="@dimen/short_margin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/never"/>

            <LinearLayout
                android:id="@+id/layoutDays"
                app:layout_constraintTop_toBottomOf="@id/tvGetDays"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvDayMon"
                    android:layout_margin="@dimen/vShort_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mon"
                    android:gravity="center"
                    android:background="@drawable/bg_day"/>
                <TextView
                    android:id="@+id/tvDayTue"
                    android:layout_margin="@dimen/vShort_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tue"
                    android:gravity="center"
                    android:background="@drawable/bg_day"/>
                <TextView
                    android:id="@+id/tvDayWed"
                    android:layout_margin="@dimen/vShort_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wed"
                    android:gravity="center"
                    android:background="@drawable/bg_day"/>
                <TextView
                    android:id="@+id/tvDayThu"
                    android:layout_margin="@dimen/vShort_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/thu"
                    android:gravity="center"
                    android:background="@drawable/bg_day"/>
                <TextView
                    android:id="@+id/tvDayFri"
                    android:layout_margin="@dimen/vShort_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fri"
                    android:gravity="center"
                    android:background="@drawable/bg_day"/>
                <TextView
                    android:id="@+id/tvDaySat"
                    android:layout_margin="@dimen/vShort_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sat"
                    android:gravity="center"
                    android:background="@drawable/bg_day"/>
                <TextView
                    android:id="@+id/tvDaySun"
                    android:layout_margin="@dimen/vShort_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sun"
                    android:gravity="center"
                    android:background="@drawable/bg_day"/>
            </LinearLayout>
        </LinearLayout>

            <com.google.android.material.textfield.TextInputEditText
                android:padding="@dimen/short_margin"
                android:inputType="text"
                android:id="@+id/etScenarioName"
                android:textColor="@color/text_color"
                android:background="@drawable/bg_name_textview"
                app:layout_constraintTop_toBottomOf="@id/layoutRepeat_nDays"
                app:layout_constraintBottom_toTopOf="@id/layoutMode"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="match_parent"
                android:layout_height="@dimen/uxLong_margin"
                android:hint="@string/scenario_name"
                android:autofillHints="Scenario 1" />

            <RelativeLayout
                android:id="@+id/layoutMode"
                android:padding="@dimen/short_margin"
                android:background="@drawable/bg_name_textview"
                app:layout_constraintTop_toBottomOf="@id/etScenarioName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toTopOf="@id/layoutMediaVolume"
                android:layout_width="match_parent"
                android:gravity="center"
                android:layout_height="@dimen/uxLong_margin">
                <TextView
                    android:layout_width="@dimen/uxLong_margin"
                    android:layout_height="wrap_content"
                    android:text="@string/mode"
                    android:layout_alignParentStart="true"
                    android:textSize="@dimen/big_text"
                    android:textStyle="bold"
                    />
                <Spinner
                    android:id="@+id/spinnerMode"
                    android:layout_alignParentEnd="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:spinnerMode="dropdown"/>
            </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutMediaVolume"
            app:layout_constraintTop_toBottomOf="@id/layoutMode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        <TextView
            android:id="@+id/tvVolumeText"
            android:layout_marginTop="@dimen/short_margin"
            android:layout_width="wrap_content"
            android:textStyle="bold"
            android:textSize="@dimen/big_text"
            android:layout_height="wrap_content"
            android:text="@string/media_volume"/>
        <SeekBar
            android:id="@+id/sbMediaVolume"
            android:layout_marginVertical="@dimen/long_margin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/bottomLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="@dimen/hLong_margin"
        android:gravity="center">
        <TextView
            android:textSize="@dimen/big_text"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivSave"
            android:gravity="center"
            android:id="@+id/tvCancel"
            android:text="@string/cancel"
            android:layout_marginStart="@dimen/long_margin"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"/>

        <TextView
            android:textSize="@dimen/big_text"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvCancel"
            android:gravity="center"
            android:id="@+id/ivSave"
            android:layout_marginEnd="@dimen/long_margin"
            android:text="@string/save"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout></ScrollView></layout>