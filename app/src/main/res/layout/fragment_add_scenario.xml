<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg"
    tools:context=".fragments.AddScenarioFragment">
    <TextView
        android:layout_marginStart="24dp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cvScenarioAttrib"
        app:layout_constraintEnd_toStartOf="@id/tvEndTime"
        android:id="@+id/tvStartTime"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="@string/set_start_time"
        android:textSize="32sp" />
    <TextView
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvStartTime"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cvScenarioAttrib"
        android:id="@+id/tvEndTime"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="@string/set_end_time"
        android:textSize="32sp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvScenarioAttrib"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="240dp"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="32dp"
        app:layout_constraintBottom_toTopOf="@id/bottomLayout">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:padding="32dp"
            android:layout_height="match_parent">
            <EditText
                android:id="@+id/etScenarioName"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/scenario_name" />




        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>








    <androidx.constraintlayout.widget.ConstraintLayout
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/bottomLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center">
        <TextView
            android:textSize="16sp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivSave"
            android:gravity="center"
            android:id="@+id/tvCancel"
            android:text="@string/cancel"
            android:layout_marginStart="16dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"/>

        <TextView
            android:textSize="16sp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvCancel"
            android:gravity="center"
            android:id="@+id/ivSave"
            android:layout_marginEnd="16dp"
            android:text="@string/save"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout></layout>